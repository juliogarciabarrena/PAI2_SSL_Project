# =============================================================================
# .gitignore — PAI-2 VPN SSL
# =============================================================================

# -----------------------------------------------------------------------------
# Maven
# -----------------------------------------------------------------------------
target/
*.jar
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
release.properties

# -----------------------------------------------------------------------------
# Base de datos SQLite
# -----------------------------------------------------------------------------
*.db
*.db-shm
*.db-wal

# -----------------------------------------------------------------------------
# Certificados y claves (NO subir al repositorio)
# -----------------------------------------------------------------------------
certs/
*.jks
*.cer
*.p12
*.pem
*.key

# -----------------------------------------------------------------------------
# Capturas de tráfico
# -----------------------------------------------------------------------------
*.pcap
*.pcapng

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# IDEs
# -----------------------------------------------------------------------------

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Eclipse
.classpath
.project
.settings/

# VS Code
.vscode/

# NetBeans
nbproject/
nb-configuration.xml

# -----------------------------------------------------------------------------
# Sistema operativo
# -----------------------------------------------------------------------------

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.Spotlight-V100
.Trashes

# -----------------------------------------------------------------------------
# Variables de entorno locales
# -----------------------------------------------------------------------------
.env
*.env.local